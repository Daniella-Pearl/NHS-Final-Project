doctype html
head
  meta(charset='utf-8')
  meta(http-equiv='X-UA-Compatible' content='IE=edge')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  meta(name='description' content='')
  meta(name='author' content='')
  title Password Reset
  link(href='/css/password.css' rel='stylesheet')
  link(href='https://fonts.googleapis.com/css2?family=Bitcount+Grid+Double+Ink:wght@100..900&family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Serif:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&family=Miniver&family=Montagu+Slab:opsz,wght@16..144,100..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Prata&family=Sofia&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&family=Spectral:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap' rel='stylesheet')
  script(src='https://use.fontawesome.com/releases/v6.3.0/js/all.js' crossorigin='anonymous')
#layoutAuthentication
  #layoutAuthentication_content
    main
      .container
        .row.justify-content-center
          .col-lg-5
            .card.shadow-lg.border-0.rounded-lg.mt-5
              .card-header
                h3.text-center.font-weight-light.my-4.create
                  | Password Recovery
              .card-body
                .small.mb-3.text-muted
                  | Enter your email address and we will send you a link to
                  | reset your password.
                form(action='/password' method='post')
                  .form-floating.mb-3
                    input#inputEmail.form-control(name='inputemail' type='email' placeholder='name@example.com')
                    label(for='inputEmail') Email address
                  .d-flex.align-items-center.justify-content-between.mt-4.mb-0
                    a.small(href='/login') Return to login
                    //
                      <a class="btn btn-primary butn" href="login.html"
                      >Reset Password</a
                      >
                    button.butn(type='submit') Reset
              .card-footer.text-center.py-3
                .small
                  a(href='#') Have any questions? Contact Admin.
  #layoutAuthentication_footer
    footer.py-2.bg-light.mt-auto
      .container-fluid.px-4
        .d-flex.align-items-center.justify-content-between.small
          .text-muted &copy; NyondoStock Hardware 2026
          div
            a(href='#') Privacy Policy
            |                 &middot;
            a(href='#') Terms &amp; Conditions
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js' crossorigin='anonymous')
script(src='js/scripts.js')
