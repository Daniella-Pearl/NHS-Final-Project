doctype html
head
  meta(charset='utf-8')
  meta(http-equiv='X-UA-Compatible' content='IE=edge')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  title Register
  link(href='/css/password.css' rel='stylesheet')
  link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap' rel='stylesheet')
  script(src='https://use.fontawesome.com/releases/v6.3.0/js/all.js' crossorigin='anonymous')
#layoutAuthentication
  #layoutAuthentication_content
    main
      .container
        .row.justify-content-center
          .col-lg-7
            .card.shadow-lg.border-0.rounded-lg.mt-5
              .card-header
                h3.text-center.font-weight-light.my-4.create Create Account
              .card-body
                form(action='/register' method='post')
                  .row.mb-3
                    .col-md-6
                      .form-floating.mb-3.mb-md-0
                        input#inputFirstName.form-control(type='text' name='inputFirstName' placeholder='Enter your first name' required='')
                        label(for='inputFirstName') First name
                    .col-md-6
                      .form-floating
                        input#inputLastName.form-control(name='inputLastName' type='text' placeholder='Enter your last name' required='')
                        label(for='inputLastName') Last name
                  .form-floating.mb-3
                    input#inputEmail.form-control(name='inputEmail' type='email' placeholder='name@example.com' required='')
                    label(for='inputEmail') Email address
                  .row.mb-3
                    .col-md-6
                      .form-floating.mb-3.mb-md-0
                        input#inputPhone.form-control(name='inputPhone' type='tel' placeholder='0700 000 000' required='')
                        label(for='inputPhone') Phone Number
                    .col-md-6
                      .form-floating
                        input#inputNIN.form-control(name='inputNIN' type='text' placeholder='NIN Number' required='')
                        label(for='inputNIN') NIN (ID Number)
                  .form-floating.mb-3
                    select#inputRole.form-select(name='inputRole' aria-label='Select User Role' required='')
                      option(value='' selected='' disabled='') Select a role
                      option(value='admin') Admin
                      option(value='manager') Manager
                      option(value='sales') Sales Associate
                      option(value='inventory') Inventory Manager
                    label(for='inputRole') User Role
                  .row.mb-3
                    .col-md-6
                      .form-floating.mb-3.mb-md-0
                        input#inputPassword.form-control(name='inputPassword' type='password' placeholder='Create a password' required='')
                        label(for='inputPassword') Password
                    .col-md-6
                      .form-floating.mb-3.mb-md-0
                        input#inputPasswordConfirm.form-control(name='inputPasswordConfirm' type='password' placeholder='Confirm password' required='')
                        label(for='inputPasswordConfirm') Confirm Password
                  .mt-4.mb-0
                    .d-grid.createAccount
                      button.butn(type='submit') Create Account
              .card-footer.text-center.py-3
                .small
                  a(href='users.html') Not sure? Check Registered List!
  #layoutAuthentication_footer
    footer.py-2.bg-light.mt-auto
      .container-fluid.px-4
        .d-flex.align-items-center.justify-content-between.small
          .text-muted &copy; NyondoStock Hardware 2026
          div
            a(href='#') Privacy Policy
            |                 &middot;
            a(href='#') Terms &amp; Conditions
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js' crossorigin='anonymous')
script(src='js/scripts.js')
